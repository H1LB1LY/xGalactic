# Discord Bot Token (https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# xAI Grok API Key (https://console.x.ai/) — admin-only, never commit real keys
XAI_API_KEY=your_xai_api_key_here

# Default Grok model: grok-4.1-fast | grok-4.3
GROK_MODEL=grok-4.1-fast

# SQLite database path (relative or absolute)
DATABASE_PATH=data/xgalactic.db

# Optional: global rate limits (per minute)
RATE_LIMIT_GUILD=60
RATE_LIMIT_USER=10

# Optional: logging channel ID (set per-guild via /config instead)
# LOG_CHANNEL_ID=
